use "jik/testing" as test
use "test/jik/utils"

func run_tests(ts):

    // Returning local region
    utils::assert_compile_fails_source(ts,
"""
func foo():
    x := [3 of 0]
    return x
end


func main():
    res := foo()
end   
"""
    )

    // Mixing region arguments
    utils::assert_compile_fails_source(ts,
"""
func bar(r1, r2):
end

func foo(r):
    bar(r, _)
end


func main():
    foo(_)
end
"""
    )

    // Subscript set to local region
    utils::assert_compile_fails_source(ts,
"""
func foo(v):
    x := [0 of 0]
    v[0] = x
end


func main():
    v := [3 of [2 of 1]]
    foo(v)
end
"""
    )

    // Push element from local region
    utils::assert_compile_fails_source(ts,
"""
func foo(v):
    x := [0 of 0]
    push(v, x)
end


func main():
    v := [3 of [2 of 1]]
    foo(v)
end
"""
    )

    // foreign
    utils::assert_compile_fails_source(ts,
"""
func foo(foreign v1, v2):
    v1[0] = v2
end


func main():
    v := [3 of [2 of 1]]
    x := [2, 6]
    foo(v, x)
end
"""
    )

    // Returning foreign composite
    utils::assert_compile_fail_source(ts,
"""
func id_foreign(foreign s: String) -> String:
    return s
end

func main():
    x := "abc"
    y := id_foreign(x)
end
""",
        "cannot return foreign composite value"
    )

end
