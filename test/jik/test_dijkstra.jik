use "jik/testing" as test


INF := 1000000000


func dijkstra_calc(w: Vec[Vec[int]], src: int, r: Region) -> Vec[int]:
    n := len(w)

    dist := [n of INF][r]
    used := [n of false][r]

    dist[src] = 0

    for i = 0, n:
        best_v := -1
        best_d := INF

        for v = 0, n:
            if not used[v] and dist[v] < best_d:
                best_d = dist[v]
                best_v = v
            end
        end

        if best_v == -1:
            break
        end

        used[best_v] = true

        for to = 0, n:
            wt := w[best_v][to]
            if wt < INF:
                if dist[best_v] + wt < dist[to]:
                    dist[to] = dist[best_v] + wt
                end
            end
        end
    end

    return dist
end


func run_tests(ts):
    w := [
        [0,   10,  3,   INF, INF],
        [INF, 0,   1,   2,   INF],
        [INF, 4,   0,   8,   2],
        [INF, INF, INF, 0,   7],
        [INF, INF, INF, 9,   0]
    ]

    d := dijkstra_calc(w, 0, _)

    test::suite_assert(ts, d[0] == 0, site())
    test::suite_assert(ts, d[1] == 7, site())
    test::suite_assert(ts, d[2] == 3, site())
    test::suite_assert(ts, d[3] == 9, site())
    test::suite_assert(ts, d[4] == 5, site())

end
