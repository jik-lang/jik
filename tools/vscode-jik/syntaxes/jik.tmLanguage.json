{
  "name": "Jik",
  "scopeName": "source.jik",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtin-types" },
    { "include": "#builtin-functions" },
    { "include": "#type-defs" },
    { "include": "#function-defs" },
    { "include": "#module-access" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//!.*$",
          "name": "comment.line.documentation.jik"
        },
        {
          "match": "///.*$",
          "name": "comment.line.documentation.jik"
        },
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.jik"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "match": "@[A-Za-z_][A-Za-z0-9_]*(\\{[A-Za-z_][A-Za-z0-9_]*\\})?",
          "name": "meta.annotation.jik"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.jik",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.jik"
            }
          ]
        },
        {
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.jik",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.jik"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b\\d+(?:\\.\\d+)?\\b",
          "name": "constant.numeric.jik"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(func|struct|enum|variant|if|elif|else|while|for|end|return|of|this|break|continue|use|as|true|false|and|or|not|extern|init|hints|must|try|except|throws|foreign|is)\\b",
          "name": "keyword.control.jik"
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "match": "\\b(void|bool|char|int|double|String|Region|Site|Vec|Dict|Option|Result)\\b",
          "name": "support.type.jik"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "match": "\\b(print|println|concat|assert|push|pop|len|clear|site|site_file|site_line|site_code|fail|error_msg|error_code)\\b(?=\\s*\\()",
          "name": "support.function.builtin.jik"
        }
      ]
    },
    "type-defs": {
      "patterns": [
        {
          "match": "\\b(struct|enum|variant)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.jik" },
            "2": { "name": "entity.name.type.jik" }
          }
        }
      ]
    },
    "function-defs": {
      "patterns": [
        {
          "match": "\\bfunc\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.jik" }
          }
        }
      ]
    },
    "module-access": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(::)([A-Za-z_][A-Za-z0-9_]*)?",
          "captures": {
            "1": { "name": "entity.name.namespace.jik" },
            "2": { "name": "punctuation.accessor.double-colon.jik" },
            "3": { "name": "support.function.jik" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b[A-Z][A-Z0-9_]*\\b",
          "name": "constant.language.jik"
        }
      ]
    }
  }
}
